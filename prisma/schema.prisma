generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

enum ExpenseCategory {
  UTILITIES
  PAYROLL
  SUPPLIES
  MARKETING
  RENT
  SOFTWARE
  TAXES
  OTHER
}

enum InventoryUnit {
  UNIT
  BOX
  VIAL
  SYRINGE
  ML
  MG
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  WASTE
  EXPIRATION
  RETURN
}

enum SaleItemType {
  TREATMENT
  PRODUCT
}

model Patient {
  id                 String    @id @default(cuid())
  firstName          String
  lastName           String
  identification     String    @unique
  phone              String
  email              String?   @unique
  birthDate          DateTime?
  allergies          String?
  previousTreatments String?
  importantNotes     String?
  lastVisitAt        DateTime?
  nextVisitAt        DateTime?
  revenues           Revenue[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([lastName, firstName])
  @@index([lastVisitAt])
  @@index([nextVisitAt])
}

model Supplier {
  id                String    @id @default(cuid())
  companyName       String
  commercialAdvisor String?
  phone             String?
  email             String?   @unique
  notes             String?
  products          Product[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyName])
}

model Product {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  sku                String?             @unique
  lotNumber          String
  costPrice          Decimal?            @db.Decimal(12, 2)
  stockQuantity      Decimal             @db.Decimal(10, 2)
  minStockQuantity   Decimal             @db.Decimal(10, 2)
  unit               InventoryUnit
  expiresAt          DateTime?
  isActive           Boolean             @default(true)
  supplierId         String
  supplier           Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  saleItem           SaleItem?
  serviceComponents  SaleItemComponent[]
  revenueUsages      RevenueInventoryUsage[]
  inventoryMovements InventoryMovement[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([name])
  @@index([supplierId])
  @@index([expiresAt])
}

model SaleItem {
  id          String       @id @default(cuid())
  name        String
  type        SaleItemType
  description String?
  unitPrice   Decimal      @db.Decimal(12, 2)
  baseCost    Decimal?     @db.Decimal(12, 2)
  isActive    Boolean      @default(true)
  productId   String?      @unique
  product     Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  components  SaleItemComponent[]
  revenues    Revenue[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([type])
  @@index([name])
}

model Revenue {
  id            String        @id @default(cuid())
  occurredAt    DateTime      @default(now())
  amount        Decimal       @db.Decimal(12, 2)
  costAmount    Decimal?      @db.Decimal(12, 2)
  paymentMethod PaymentMethod
  notes         String?
  patientId     String
  saleItemId    String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Restrict)
  saleItem      SaleItem      @relation(fields: [saleItemId], references: [id], onDelete: Restrict)
  inventoryUsages RevenueInventoryUsage[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([occurredAt])
  @@index([patientId])
  @@index([saleItemId])
}

model SaleItemComponent {
  id         String   @id @default(cuid())
  saleItemId String
  productId  String
  quantity   Decimal  @db.Decimal(10, 2)
  saleItem   SaleItem @relation(fields: [saleItemId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([saleItemId, productId])
  @@index([saleItemId])
  @@index([productId])
}

model RevenueInventoryUsage {
  id         String   @id @default(cuid())
  revenueId  String
  productId  String
  quantity   Decimal  @db.Decimal(10, 2)
  unitCost   Decimal? @db.Decimal(12, 2)
  totalCost  Decimal? @db.Decimal(12, 2)
  revenue    Revenue  @relation(fields: [revenueId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([revenueId])
  @@index([productId])
}

model Expense {
  id          String          @id @default(cuid())
  occurredAt  DateTime        @default(now())
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  description String
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([occurredAt])
  @@index([category])
}

model InventoryMovement {
  id         String                @id @default(cuid())
  occurredAt DateTime              @default(now())
  type       InventoryMovementType
  quantity   Decimal               @db.Decimal(10, 2)
  reason     String?
  productId  String
  product    Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt  DateTime              @default(now())

  @@index([occurredAt])
  @@index([productId])
  @@index([type])
}
